<% if user_signed_in? && current_user == "admin@test.info" %>
  <%= form_with(model: category) do |form| %>
    <% if category.errors.any? %>
      <div style="color: red">
        <h2><%= pluralize(category.errors.count, "error") %> prohibited this category from being saved:</h2>
        <ul>
          <% category.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    <%= form.label :category_name, style: "display: block" %>
    <%= form.text_field :category_name %>
    <%= form.label :category_description, style: "display: block" %>
    <%= form.text_field :category_description %>
    <%= form.select :category_designator, ['novel', 'nonfiction']%>
    <div>
      <%= form.submit %>
    </div>
  <% end %>
<% end %>
